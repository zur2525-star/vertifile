<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PVF - מסמך מאומת</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;900&family=Frank+Ruhl+Libre:wght@400;700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Heebo', sans-serif;
      background: #e8e8e8;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 30px 20px;
    }

    body.forged-mode { background: #3a1010; }

    /* ===== LOADING ===== */
    .loading-screen {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.6s ease;
    }
    .loading-screen.hidden { opacity: 0; pointer-events: none; }
    .loading-spinner {
      width: 50px; height: 50px;
      border: 3px solid #e0e0e0;
      border-top-color: #1a237e;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 20px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-msg { color: #666; font-size: 16px; }

    /* ===== DEMO BUTTONS (small, top corner) ===== */
    .demo-bar {
      position: fixed;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      display: none;
      gap: 8px;
      z-index: 200;
      background: rgba(0,0,0,0.7);
      padding: 6px 12px;
      border-radius: 20px;
      backdrop-filter: blur(10px);
    }
    .demo-btn {
      padding: 5px 14px;
      border: none;
      border-radius: 12px;
      font-family: 'Heebo', sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      color: rgba(255,255,255,0.6);
      background: transparent;
      transition: all 0.2s;
    }
    .demo-btn.on { color: #fff; background: rgba(255,255,255,0.15); }

    /* ===== THE DOCUMENT (A4-like page) ===== */
    .page {
      background: white;
      width: 100%;
      max-width: 800px;
      min-height: 1050px;
      box-shadow: 0 4px 40px rgba(0,0,0,0.15);
      position: relative;
      padding: 60px 65px;
      transition: box-shadow 0.5s;
    }

    .page.forged {
      box-shadow: 0 0 0 4px #e53935, 0 4px 40px rgba(255,0,0,0.3);
    }

    /* ===== DOCUMENT CONTENT ===== */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid #1a237e;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }

    .org-info { text-align: right; }
    .org-name { font-size: 22px; font-weight: 900; color: #1a237e; }
    .org-name-en { font-size: 13px; color: #666; font-weight: 400; }
    .org-details { font-size: 11px; color: #999; margin-top: 4px; line-height: 1.6; }

    .org-logo {
      width: 70px; height: 70px;
      background: linear-gradient(135deg, #1a237e, #0d47a1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .org-logo svg { width: 40px; height: 40px; }

    .doc-type {
      text-align: center;
      font-family: 'Frank Ruhl Libre', serif;
      font-size: 28px;
      font-weight: 700;
      color: #1a237e;
      margin: 25px 0 30px;
      letter-spacing: 2px;
    }

    .doc-body-text {
      font-size: 16px;
      line-height: 2.2;
      color: #333;
      text-align: justify;
      margin-bottom: 25px;
    }

    .doc-body-text .highlight {
      font-weight: 900;
      color: #1a237e;
    }

    .details-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid #ddd;
      border-radius: 8px;
      overflow: hidden;
      margin: 25px 0;
    }

    .detail-cell {
      padding: 12px 18px;
      border-bottom: 1px solid #eee;
      font-size: 14px;
    }

    .detail-cell:nth-child(odd) {
      background: #f8f9ff;
      font-weight: 700;
      color: #1a237e;
      border-left: 1px solid #eee;
    }

    .detail-cell:nth-last-child(-n+2) { border-bottom: none; }

    .doc-paragraph {
      font-size: 14px;
      line-height: 1.9;
      color: #555;
      margin: 20px 0;
      text-align: justify;
    }

    .signature-area {
      display: flex;
      justify-content: space-between;
      margin-top: 50px;
      padding-top: 20px;
    }

    .sig-block {
      text-align: center;
      width: 180px;
    }

    .sig-line {
      border-top: 1px solid #333;
      margin-bottom: 6px;
      margin-top: 40px;
    }

    .sig-name { font-size: 13px; font-weight: 700; color: #333; }
    .sig-title { font-size: 11px; color: #999; }

    .doc-number {
      position: absolute;
      bottom: 25px;
      left: 65px;
      font-size: 10px;
      color: #bbb;
      direction: ltr;
    }

    /* ============================================ */
    /* ===== THE ANIMATED STAMP (35% overlay) ===== */
    /* ============================================ */
    .stamp-overlay {
      position: absolute;
      bottom: 120px;
      left: 50%;
      transform: translateX(-50%);
      width: 35%;
      aspect-ratio: 1;
      z-index: 50;
      pointer-events: none;
    }

    .stamp-ring {
      width: 100%;
      height: 100%;
      position: relative;
    }

    /* Outer rotating ring */
    .stamp-outer {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      animation: stampRotate 25s linear infinite;
    }

    .stamp-outer.frozen { animation: none !important; }

    @keyframes stampRotate {
      to { transform: rotate(360deg); }
    }

    /* Holographic shimmer effect */
    .stamp-shimmer {
      position: absolute;
      top: 5%; left: 5%;
      width: 90%; height: 90%;
      border-radius: 50%;
      background: conic-gradient(
        from 0deg,
        rgba(26,35,126,0.06) 0deg,
        rgba(13,71,161,0.12) 60deg,
        rgba(76,175,80,0.08) 120deg,
        rgba(26,35,126,0.06) 180deg,
        rgba(13,71,161,0.12) 240deg,
        rgba(76,175,80,0.08) 300deg,
        rgba(26,35,126,0.06) 360deg
      );
      animation: shimmerRotate 4s linear infinite;
    }

    .stamp-shimmer.frozen {
      animation: none !important;
      background: rgba(244,67,54,0.08);
    }

    @keyframes shimmerRotate {
      to { transform: rotate(-360deg); }
    }

    /* Inner glow pulse */
    .stamp-glow {
      position: absolute;
      top: 15%; left: 15%;
      width: 70%; height: 70%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(76,175,80,0.1) 0%, transparent 70%);
      animation: glowPulse 3s ease-in-out infinite;
    }

    .stamp-glow.frozen {
      animation: none !important;
      background: radial-gradient(circle, rgba(244,67,54,0.1) 0%, transparent 70%);
    }

    @keyframes glowPulse {
      0%, 100% { opacity: 0.5; transform: scale(0.95); }
      50% { opacity: 1; transform: scale(1.05); }
    }

    /* Center content */
    .stamp-center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    }

    .stamp-check {
      width: 45%;
      margin: 0 auto;
    }

    .stamp-check-path {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: drawStampCheck 1s ease forwards 1.5s;
    }

    @keyframes drawStampCheck { to { stroke-dashoffset: 0; } }

    .stamp-x-path {
      stroke-dasharray: 40;
      stroke-dashoffset: 40;
      animation: drawStampX 0.5s ease forwards;
    }
    .stamp-x-path:nth-child(2) { animation-delay: 0.3s; }
    @keyframes drawStampX { to { stroke-dashoffset: 0; } }

    .stamp-label {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 1px;
      margin-top: 4px;
    }

    .stamp-label.valid { color: rgba(46,125,50,0.7); }
    .stamp-label.invalid { color: rgba(198,40,40,0.7); }

    /* Forged red X overlay on page */
    .forged-giant-x {
      display: none;
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      z-index: 40;
      pointer-events: none;
    }

    .forged-giant-x.visible { display: block; }

    .forged-giant-x svg {
      width: 100%;
      height: 100%;
    }

    .forged-text-watermark {
      display: none;
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%) rotate(-35deg);
      font-size: 72px;
      font-weight: 900;
      color: rgba(229,57,53,0.1);
      white-space: nowrap;
      z-index: 45;
      pointer-events: none;
      letter-spacing: 10px;
    }

    .forged-text-watermark.visible { display: block; }

    /* ===== SMALL STATUS BAR (bottom) ===== */
    .status-strip {
      max-width: 800px;
      width: 100%;
      margin-top: 12px;
      display: none;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 12px;
      color: #888;
      padding: 8px;
    }

    .status-strip .mini-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #4caf50;
      animation: pulse-dot 2s infinite;
    }

    .status-strip .mini-dot.fail {
      background: #f44336;
      animation: pulse-dot-red 1s infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }
    @keyframes pulse-dot-red {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 650px) {
      .page { padding: 30px 25px; min-height: auto; }
      .doc-type { font-size: 22px; }
      .page-header { flex-direction: column-reverse; gap: 15px; align-items: center; text-align: center; }
      .org-info { text-align: center; }
      .details-grid { grid-template-columns: 1fr; }
      .detail-cell:nth-child(odd) { border-left: none; }
      .signature-area { flex-direction: column; align-items: center; gap: 30px; }
      .stamp-overlay { width: 50%; }
    }
  </style>
</head>
<body>

  <!-- LOADING -->
  <div class="loading-screen" id="loadingScreen">
    <div class="loading-spinner"></div>
    <div class="loading-msg">מאמת מסמך...</div>
  </div>

  <!-- DEMO BAR -->
  <div class="demo-bar" id="demoBar">
    <button class="demo-btn on" id="btnOk" onclick="demoValid()">מקורי</button>
    <button class="demo-btn" id="btnFake" onclick="demoForged()">זיוף</button>
  </div>

  <!-- ===== THE DOCUMENT PAGE ===== -->
  <div class="page" id="thePage" style="display:none;">

    <!-- Forged overlays -->
    <div class="forged-giant-x" id="forgedX">
      <svg viewBox="0 0 800 1050" preserveAspectRatio="none">
        <line x1="50" y1="50" x2="750" y2="1000" stroke="rgba(229,57,53,0.08)" stroke-width="60" stroke-linecap="round"/>
        <line x1="750" y1="50" x2="50" y2="1000" stroke="rgba(229,57,53,0.08)" stroke-width="60" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="forged-text-watermark" id="forgedWatermark">FORGED</div>

    <!-- Page header -->
    <div class="page-header">
      <div class="org-info">
        <div class="org-name">אוניברסיטת תל אביב</div>
        <div class="org-name-en">Tel Aviv University</div>
        <div class="org-details">
          רמת אביב, ת.ד. 39040, תל אביב 6997801<br>
          טל: 03-6408111 | www.tau.ac.il
        </div>
      </div>
      <div class="org-logo">
        <svg viewBox="0 0 40 40" fill="none">
          <path d="M20 4 L23 16 H34 L25 23 L28 35 L20 28 L12 35 L15 23 L6 16 H17 Z" fill="white" opacity="0.9"/>
        </svg>
      </div>
    </div>

    <!-- Document type -->
    <div class="doc-type">תעודת סיום לימודים</div>

    <!-- Main text -->
    <div class="doc-body-text">
      אוניברסיטת תל אביב מאשרת בזאת כי <span class="highlight">יוסי כהן</span>,
      ת.ז. <span class="highlight">305XXXXXX</span>,
      סיים בהצלחה את כל חובותיו האקדמיות
      והינו זכאי לתואר <span class="highlight">בוגר במדעי המחשב (B.Sc.)</span>
      מהפקולטה למדעים מדויקים ע"ש ריימונד ובברלי סאקלר.
    </div>

    <!-- Details grid -->
    <div class="details-grid">
      <div class="detail-cell">שם הסטודנט</div>
      <div class="detail-cell">יוסי כהן</div>
      <div class="detail-cell">תואר</div>
      <div class="detail-cell">בוגר במדעי המחשב (B.Sc.)</div>
      <div class="detail-cell">פקולטה</div>
      <div class="detail-cell">מדעים מדויקים ע"ש סאקלר</div>
      <div class="detail-cell">ממוצע ציונים</div>
      <div class="detail-cell">92.4</div>
      <div class="detail-cell">תאריך הענקה</div>
      <div class="detail-cell">17 במרץ, 2026</div>
      <div class="detail-cell">מספר תעודה</div>
      <div class="detail-cell" style="direction:ltr;text-align:right;">PVF-2024-00482</div>
    </div>

    <div class="doc-paragraph">
      תעודה זו הונפקה באמצעות מערכת PVF (Protected Verified File) ומאובטחת קריפטוגרפית.
      כל שינוי בתוכן המסמך יוביל לכשל מיידי באנימציית האימות.
      ניתן לאמת את המסמך בכל עת בכתובת verify.pvf.co.il.
    </div>

    <!-- Signatures -->
    <div class="signature-area">
      <div class="sig-block">
        <div class="sig-line"></div>
        <div class="sig-name">פרופ' אריאל פורת</div>
        <div class="sig-title">נשיא האוניברסיטה</div>
      </div>
      <div class="sig-block">
        <div class="sig-line"></div>
        <div class="sig-name">פרופ' מירה בלבן</div>
        <div class="sig-title">דקנית הפקולטה</div>
      </div>
    </div>

    <div class="doc-number">PVF-2024-00482 | Polygon Blockchain Verified</div>

    <!-- ===== THE ANIMATED STAMP ===== -->
    <div class="stamp-overlay" id="stampOverlay">
      <div class="stamp-ring">
        <!-- SVG rotating outer ring -->
        <svg class="stamp-outer" id="stampOuter" viewBox="0 0 200 200">
          <circle cx="100" cy="100" r="95" fill="none" stroke="rgba(26,35,126,0.25)" stroke-width="1.5"/>
          <circle cx="100" cy="100" r="88" fill="none" stroke="rgba(26,35,126,0.15)" stroke-width="0.5" stroke-dasharray="4 4"/>

          <!-- Tick marks -->
          <line x1="100" y1="2" x2="100" y2="10" stroke="rgba(26,35,126,0.3)" stroke-width="1.5"/>
          <line x1="100" y1="190" x2="100" y2="198" stroke="rgba(26,35,126,0.3)" stroke-width="1.5"/>
          <line x1="2" y1="100" x2="10" y2="100" stroke="rgba(26,35,126,0.3)" stroke-width="1.5"/>
          <line x1="190" y1="100" x2="198" y2="100" stroke="rgba(26,35,126,0.3)" stroke-width="1.5"/>

          <!-- Circular text -->
          <defs>
            <path id="tp" d="M100,100 m-78,0 a78,78 0 1,1 156,0 a78,78 0 1,1 -156,0"/>
          </defs>
          <text font-size="7.5" fill="rgba(26,35,126,0.35)" font-weight="700" letter-spacing="2">
            <textPath href="#tp">PROTECTED VERIFIED FILE \u2022 BLOCKCHAIN SECURED \u2022 AUTHENTIC \u2022</textPath>
          </text>
        </svg>

        <!-- Holographic shimmer -->
        <div class="stamp-shimmer" id="stampShimmer"></div>

        <!-- Glow pulse -->
        <div class="stamp-glow" id="stampGlow"></div>

        <!-- Inner circle + check/x -->
        <svg style="position:absolute;top:20%;left:20%;width:60%;height:60%;" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="48" fill="rgba(255,255,255,0.6)" stroke="rgba(26,35,126,0.2)" stroke-width="1"/>
        </svg>

        <!-- Center icon -->
        <div class="stamp-center" id="stampCenter">
          <!-- filled by JS -->
        </div>
      </div>
    </div>

  </div>

  <!-- STATUS STRIP -->
  <div class="status-strip" id="statusStrip">
    <div class="mini-dot" id="miniDot"></div>
    <span id="stripText">מאומת | PVF Blockchain Verified</span>
  </div>

  <script>
    const API = window.location.origin;
    const DOC = {
      name: 'יוסי כהן', degree: 'בוגר במדעי המחשב (B.Sc.)',
      average: '92.4', year: '2024', docId: 'PVF-2024-00482',
      issuer: 'אוניברסיטת תל אביב'
    };

    let hash = null, token = null, forgedMode = false;

    // ===== VERIFY ON LOAD =====
    async function init() {
      try {
        await sleep(400);
        const res = await fetch(API + '/api/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: DOC })
        });
        const data = await res.json();

        if (data.verified) {
          hash = data.hash;
          token = data.token;
          showDoc(true);
          startRefresh();
        } else {
          showDoc(false);
        }
      } catch (e) {
        showDoc(false);
      }
    }

    function showDoc(verified) {
      document.getElementById('loadingScreen').classList.add('hidden');
      document.getElementById('thePage').style.display = '';
      document.getElementById('demoBar').style.display = 'flex';
      document.getElementById('statusStrip').style.display = 'flex';

      if (verified) setValid(); else setForged();
    }

    // ===== VALID STATE =====
    function setValid() {
      forgedMode = false;
      document.body.classList.remove('forged-mode');
      document.getElementById('thePage').classList.remove('forged');
      document.getElementById('forgedX').classList.remove('visible');
      document.getElementById('forgedWatermark').classList.remove('visible');

      document.getElementById('stampOuter').classList.remove('frozen');
      document.getElementById('stampShimmer').classList.remove('frozen');
      document.getElementById('stampGlow').classList.remove('frozen');

      document.getElementById('stampCenter').innerHTML = `
        <svg class="stamp-check" viewBox="0 0 50 50" fill="none" style="width:40px;">
          <path class="stamp-check-path" d="M12 26 L22 36 L38 16"
                stroke="rgba(46,125,50,0.6)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="stamp-label valid">VERIFIED</div>
      `;

      document.getElementById('miniDot').className = 'mini-dot';
      document.getElementById('stripText').textContent = 'מאומת | PVF Blockchain Verified';

      document.getElementById('btnOk').className = 'demo-btn on';
      document.getElementById('btnFake').className = 'demo-btn';
    }

    // ===== FORGED STATE =====
    function setForged() {
      forgedMode = true;
      document.body.classList.add('forged-mode');
      document.getElementById('thePage').classList.add('forged');
      document.getElementById('forgedX').classList.add('visible');
      document.getElementById('forgedWatermark').classList.add('visible');

      document.getElementById('stampOuter').classList.add('frozen');
      document.getElementById('stampShimmer').classList.add('frozen');
      document.getElementById('stampGlow').classList.add('frozen');

      document.getElementById('stampCenter').innerHTML = `
        <svg style="width:40px;" viewBox="0 0 50 50" fill="none">
          <path class="stamp-x-path" d="M15 15 L35 35" stroke="rgba(198,40,40,0.6)" stroke-width="3.5" stroke-linecap="round"/>
          <path class="stamp-x-path" d="M35 15 L15 35" stroke="rgba(198,40,40,0.6)" stroke-width="3.5" stroke-linecap="round"/>
        </svg>
        <div class="stamp-label invalid">FORGED</div>
      `;

      document.getElementById('miniDot').className = 'mini-dot fail';
      document.getElementById('stripText').textContent = 'אימות נכשל | Document Tampered';

      document.getElementById('btnOk').className = 'demo-btn';
      document.getElementById('btnFake').className = 'demo-btn on';
    }

    // ===== TOKEN REFRESH =====
    function startRefresh() {
      setInterval(async () => {
        if (forgedMode) return;
        try {
          const r = await fetch(API + '/api/token/refresh', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ hash })
          });
          const d = await r.json();
          if (d.success) token = d.token;
        } catch (e) {
          setForged();
        }
      }, 30000);
    }

    // ===== DEMO =====
    function demoValid() { setValid(); }
    function demoForged() { setForged(); }

    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

    init();
  </script>
</body>
</html>
