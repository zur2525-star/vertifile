# ===== Server =====
PORT=3002
NODE_ENV=development    # development | production
BASE_URL=               # Public URL (e.g. https://vertifile.com). Auto-detected if empty
HMAC_SECRET=            # Auto-generated if empty (persisted in data/.hmac-secret)
SESSION_SECRET=         # Auto-generated if empty (persisted in data/.session_secret)
ADMIN_SECRET=           # Secret for admin dashboard access
ADMIN_EMAILS=           # Comma-separated admin emails (bypass paywall, e.g. admin@example.com,ceo@example.com)
ALLOWED_ORIGINS=        # Comma-separated allowed CORS origins
LOG_LEVEL=              # pino log level: debug | info | warn | error (default: info in prod)

# ===== Database =====
DATABASE_URL=           # PostgreSQL connection string (required)

# ===== Auth =====
BCRYPT_ROUNDS=12        # bcrypt cost factor (minimum 12)
GOOGLE_CLIENT_ID=       # Google OAuth client ID (optional, enables Google login)
GOOGLE_CLIENT_SECRET=   # Google OAuth client secret

# ===== Email (Resend SMTP -- free tier, 100 emails/day) =====
# Sign up at resend.com, add vertifile.com domain, create API key
SMTP_HOST=smtp.resend.com
SMTP_PORT=465           # 465 for SSL (Resend default)
SMTP_USER=resend        # Always "resend" for Resend SMTP
SMTP_PASS=              # Resend API key (starts with re_)
SMTP_FROM=Vertifile <noreply@vertifile.com>

# ===== Ed25519 dual-signature (Phase 2A+) =====
# Generate via: node scripts/generate-ed25519-keys.js
# Leave empty to disable Ed25519 signing (Phase 2A invisible mode)
ED25519_PRIVATE_KEY_PEM=
ED25519_PRIMARY_KEY_ID=

# ===== Feature flags (Phase 1B/2) =====
PVF_PIPELINE_V2=1
ED25519_SIGNING_ENABLED=0
ED25519_VERIFY_ENABLED=0
ED25519_REQUIRED=0

# ===== Blockchain (Polygon) =====
POLYGON_PRIVATE_KEY=    # Wallet private key (0x...)
POLYGON_CONTRACT=       # Deployed contract address (0x...)
POLYGON_NETWORK=amoy    # amoy | mumbai | polygon

# ===== Railway/Render Deployment =====
# Set these as platform environment variables, not in .env file
# RENDER=               # Auto-set by Render
# RAILWAY_STATIC_URL=   # Auto-set by Railway
